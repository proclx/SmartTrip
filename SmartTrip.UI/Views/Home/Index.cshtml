@{
    ViewData["Title"] = "Головна";
}

<div class="container my-5">
    <div class="row align-items-center rounded-3 border shadow-lg p-4 p-lg-5 bg-light">
        <div class="col-lg-7 p-3 p-lg-5 pt-lg-3 text-center text-lg-start">
            <h1 class="display-4 fw-bold lh-1 mb-4 text-primary">Сплануй ідеальну подорож за хвилини ✈️</h1>
            <p class="lead text-muted mb-4">
                SmartTrip — це твій персональний помічник. Просто вкажи куди і коли ти хочеш поїхати,
                а наш алгоритм підбере найкращі місця, готелі та складе детальний маршрут на кожен день.
            </p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-start mb-4 mb-lg-3">
                <a asp-controller="Trip" asp-action="Create" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm">
                    Створити новий маршрут
                </a>

                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg px-4 py-3 rounded-pill">
                        Приєднатися
                    </a>
                }
            </div>
        </div>
        <div class="col-lg-5 p-0 overflow-hidden text-center">
            <div class="fs-1" style="font-size: 10rem !important;">🌍🎒</div>
        </div>
    </div>
</div>

<div class="container px-4 py-5" id="featured-3">
    <h2 class="pb-2 border-bottom text-center mb-5">Чому саме SmartTrip?</h2>
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        <div class="col feature-block text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white fs-2 mb-3 rounded-circle shadow" style="width: 4rem; height: 4rem;">
                🗺️
            </div>
            <h3 class="fs-4 fw-bold">Розумні маршрути</h3>
            <p class="text-muted">Ми оптимізуємо логістику так, щоб ти встиг побачити найцікавіше, не витрачаючи час на зайві переїзди.</p>
        </div>
        <div class="col feature-block text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-success text-white fs-2 mb-3 rounded-circle shadow" style="width: 4rem; height: 4rem;">
                ⏱️
            </div>
            <h3 class="fs-4 fw-bold">Економія часу</h3>
            <p class="text-muted">Забудь про години пошуків у Google. Найкращі ресторани, пам'ятки та готелі вже зібрані для тебе.</p>
        </div>
        <div class="col feature-block text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-warning text-dark fs-2 mb-3 rounded-circle shadow" style="width: 4rem; height: 4rem;">
                📱
            </div>
            <h3 class="fs-4 fw-bold">Все в одному місці</h3>
            <p class="text-muted">Твій детальний план поїздки завжди під рукою. Більше жодного хаосу з вкладками і нотатками.</p>
        </div>
    </div>
</div>