@model SmartTrip.UI.ViewModels.TripViewModel

@{
    ViewData["Title"] = "Деталі подорожі";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Деталі подорожі</h2>
        <a class="btn btn-secondary" asp-action="Index">Назад до моїх подорожей</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">@Model.City</h4>
            <p class="mb-1"><strong>Початок:</strong> @Model.StartDate.ToString("dd.MM.yyyy")</p>
            <p class="mb-1"><strong>Кінець:</strong> @Model.EndDate.ToString("dd.MM.yyyy")</p>
            <p class="mb-1"><strong>Кількість людей:</strong> @Model.PeopleCount</p>
            <p class="mb-1"><strong>Рейтинг:</strong> @((Model.Rating.HasValue) ? Model.Rating.Value.ToString() : "не обрано")</p>

            <div class="d-flex gap-2 mb-3">
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Змінити дані подорожі</a>
                @{
                    var shareUrl = Url.Action("Details", "Trip", new { id = Model.Id }, Context.Request.Scheme);
                    var message = $"Моя подорож: {Model.City} ({Model.StartDate:dd.MM.yyyy} - {Model.EndDate:dd.MM.yyyy})";
                    var instaText = $"Моя подорож: {Model.City} ({Model.StartDate:dd.MM.yyyy} - {Model.EndDate:dd.MM.yyyy}). Переглянь тут: {shareUrl}";
                }
                <a class="btn btn-outline-primary" href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(shareUrl)&quote=@Uri.EscapeDataString(message)" target="_blank" rel="noopener noreferrer">Поділитися на Facebook</a>
                <button type="button" class="btn btn-outline-info" onclick="shareInstagram()">Поділитися в Instagram</button>
            </div>
            <script>
                function shareInstagram() {
                    const shareText = '@instaText';
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(shareText).then(function () {
                            alert('Текст скопійовано до буфера обміну. Відкрий Instagram і встав текст у пост.');
                            window.open('https://www.instagram.com/', '_blank');
                        }, function () {
                            alert('Не вдалося скопіювати текст. Відкрийте Instagram та вставте вручну.');
                            window.open('https://www.instagram.com/', '_blank');
                        });
                    } else {
                        alert('Ваш браузер не підтримує автоматичне копіювання. Відкрийте Instagram і вставте посилання вручну.');
                        window.open('https://www.instagram.com/', '_blank');
                    }
                }
            </script>
        </div>
    </div>

    <h5>Фотографії</h5>
    @if (Model.Photos == null || !Model.Photos.Any())
    {
        <p><em>Фотографії не додані</em></p>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-4 g-3 mb-3">
            @foreach (var photo in Model.Photos)
            {
                <div class="col">
                    <div class="card h-100">
                        <img src="@photo.FilePath" class="img-fluid rounded" style="height: 180px; object-fit: cover;" />
                        <div class="card-body p-2">
                            <form asp-action="DeletePhoto" method="post" class="d-grid">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tripId" value="@Model.Id" />
                                <input type="hidden" name="photoId" value="@photo.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (Model.SuggestedEvents != null && Model.SuggestedEvents.Any())
    {
        <div class="mt-5">
            <h3>🎉 Події та фестивалі під час вашої подорожі</h3>
            <p class="text-muted">Ми знайшли кілька цікавих подій у місті @Model.City на ваші дати.</p>

            <div class="row mt-3">
                @foreach (var ev in Model.SuggestedEvents)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" style="height: 150px; object-fit: cover;">
                            }
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@ev.Title</h5>
                                <p class="card-text text-muted small">@ev.Description</p>
                                <p class="card-text">
                                    <i class="bi bi-calendar-event"></i> @ev.EventDate.ToShortDateString()
                                </p>
                                <a href="@ev.LocationUrl" target="_blank" class="btn btn-outline-primary mt-auto">Деталі / Квитки</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>