@model SmartTrip.UI.ViewModels.CreateTripViewModel
@{
    ViewData["Title"] = "Створити маршрут";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">Куди вирушаємо? ✈️</h2>

                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="DestinationName" class="form-label fw-bold"></label>
                            <input asp-for="DestinationName" class="form-control form-control-lg" placeholder="Наприклад: Рим" />
                            <span asp-validation-for="DestinationName" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="StartingPoint" class="form-label fw-bold"></label>
                            <input asp-for="StartingPoint" class="form-control form-control-lg" placeholder="Наприклад: Київ" />
                            <span asp-validation-for="StartingPoint" class="text-danger"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-bold"></label>
                                <input asp-for="StartDate" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-bold"></label>
                                <input asp-for="EndDate" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Створити подорож
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}