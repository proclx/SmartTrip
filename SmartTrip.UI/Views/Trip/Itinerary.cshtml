@model SmartTrip.UI.ViewModels.ItineraryViewModel

@{
    ViewData["Title"] = "Мій розклад";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Подорож до міста @Model.CityName 🌍</h1>
        <p class="text-muted fs-5">
            З @Model.StartDate.ToString("dd.MM.yyyy") по @Model.EndDate.ToString("dd.MM.yyyy")
        </p>
        <a href="@Url.Action("ExportPdf", "Trip", new { id = Model.TripId })" class="btn btn-success btn-lg">
            📄 Завантажити PDF
        </a>
    </div>

    @if (Model.Days == null || !Model.Days.Any())
    {
        <div class="alert alert-warning text-center">
            Розклад ще генерується або сталася помилка. Спробуйте оновити сторінку за хвилину.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.StartingPoint))
        {
            <div class="row justify-content-center mb-4">
                <div class="col-md-10">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-header bg-info text-white py-3">
                            <h4 class="mb-0">🚗 Маршрути подорожі</h4>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.RouteToDestination))
                            {
                                <h5>🚗 Туди (з @Model.StartingPoint до @Model.CityName):</h5>
                                <div class="route-description" style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 15px;">@Html.Raw(Model.RouteToDestination.Replace("\n", "<br>"))</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.RouteBack))
                            {
                                <h5>🚗 Назад (з @Model.CityName до @Model.StartingPoint):</h5>
                                <div class="route-description" style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 15px;">@Html.Raw(Model.RouteBack.Replace("\n", "<br>"))</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-md-10">

                @foreach (var day in Model.Days)
                {
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-header bg-primary text-white py-3">
                            <h4 class="mb-0">
                                День @day.DayIndex <small class="text-light ms-2">(@day.Date.ToString("dd MMMM, dddd"))</small>
                            </h4>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @if (day.Items != null && day.Items.Any())
                                {
                                    @foreach (var item in day.Items)
                                    {
                                        <li class="list-group-item p-4">
                                            <div class="d-flex w-100 justify-content-between align-items-center">
                                                <div>
                                                    <h5 class="mb-1 text-dark fw-bold">
                                                        @if (string.Equals(item.PlaceType, "Hotel", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <span>🏨</span>
                                                        }
                                                        else if (string.Equals(item.PlaceType, "Restaurant", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <span>🍽️</span>
                                                        }
                                                        else
                                                        {
                                                            <span>📸</span>
                                                        }

                                                        @item.PlaceName
                                                    </h5>
                                                    <p class="mb-1 text-muted">@item.Notes</p>
                                                </div>
                                                <div class="text-end">
                                                    <span class="badge bg-light text-dark fs-6 border">
                                                        ⏰ @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                                    </span>
                                                    <br />
                                                    <small class="text-warning fw-bold">★ @((item.Rating ?? 0).ToString("0.0"))</small>
                                                </div>
                                            </div>
                                            <div class="mt-3">
                                                <button class="btn btn-sm btn-outline-secondary" onclick="openEditModal(@item.Id, '@item.PlaceName', '@item.Notes')">Редагувати</button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(@item.Id)">Видалити</button>
                                            </div>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item text-muted text-center py-4">
                                        Для цього дня подій не знайдено.
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

            </div>
        </div>
    }
</div>

@* Додайте модалку для редагування *@
<div class="modal fade" id="editItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редагувати пункт розкладу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editItemId" />
                <div class="mb-3">
                    <label class="form-label">Назва</label>
                    <input type="text" class="form-control" id="editItemTitle" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Опис</label>
                    <textarea class="form-control" id="editItemDesc"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" class="btn btn-primary" onclick="saveItemChanges()">Зберегти</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id, title, desc) {
            $('#editItemId').val(id);
            $('#editItemTitle').val(title);
            $('#editItemDesc').val(desc);
            var myModal = new bootstrap.Modal(document.getElementById('editItemModal'));
            myModal.show();
        }

        function saveItemChanges() {
            var id = $('#editItemId').val();
            var title = $('#editItemTitle').val();
            var desc = $('#editItemDesc').val();

            $.post('/Trip/UpdateItineraryItem', { id: id, title: title, description: desc }, function () {
                // Оновлюємо UI (або робимо location.reload())
                $('#item-' + id + ' .item-title').text(title);
                $('#item-' + id + ' .item-desc').text(desc);
                bootstrap.Modal.getInstance(document.getElementById('editItemModal')).hide();
            });
        }

        function deleteItem(id) {
            if (confirm('Ви впевнені?')) {
                $.post('/Trip/DeleteItineraryItem', { id: id }, function () {
                    $('#item-' + id).slideUp(function(){ $(this).remove(); });
                });
            }
        }
    </script>
}