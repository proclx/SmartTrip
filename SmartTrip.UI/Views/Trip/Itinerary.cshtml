@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@model SmartTrip.UI.ViewModels.ItineraryViewModel

@{
    ViewData["Title"] = "Мій розклад";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Подорож до міста @Model.CityName 🌍</h1>
        <p class="text-muted fs-5">
            З @Model.StartDate.ToString("dd.MM.yyyy") по @Model.EndDate.ToString("dd.MM.yyyy")
        </p>
        <a href="@Url.Action("ExportPdf", "Trip", new { id = Model.TripId })" class="btn btn-success btn-lg">
            📄 Завантажити PDF
        </a>
    </div>

    @if (Model.Days == null || !Model.Days.Any())
    {
        <div class="alert alert-warning text-center">
            Розклад ще генерується або сталася помилка. Спробуйте оновити сторінку за хвилину.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.StartingPoint))
        {
            <div class="row justify-content-center mb-4">
                <div class="col-md-10">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-header bg-info text-white py-3">
                            <h4 class="mb-0">🚗 Маршрути подорожі</h4>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.RouteToDestination))
                            {
                                <h5>🚗 Туди (з @Model.StartingPoint до @Model.CityName):</h5>
                                <div class="route-description">@Html.Raw(Model.RouteToDestination.Replace("\n", "<br>"))</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.RouteBack))
                            {
                                <h5>🚗 Назад (з @Model.CityName до @Model.StartingPoint):</h5>
                                <div class="route-description">@Html.Raw(Model.RouteBack.Replace("\n", "<br>"))</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-md-10">

                @foreach (var day in Model.Days)
                {
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-header bg-primary text-white py-3">
                            <h4 class="mb-0">
                                День @day.DayIndex <small class="text-light ms-2">(@day.Date.ToString("dd MMMM, dddd"))</small>
                            </h4>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @if (day.Items != null && day.Items.Any())
                                {
                                    @foreach (var item in day.Items)
                                    {
                                        <li class="list-group-item p-4" id="item-@item.Id">
                                            <div class="d-flex w-100 justify-content-between align-items-center">
                                                <div>
                                                    <h5 class="mb-1 text-dark fw-bold item-title">
                                                        @if (string.Equals(item.PlaceType, "Hotel", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <span>🏨</span>
                                                        }
                                                        else if (string.Equals(item.PlaceType, "Restaurant", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <span>🍽️</span>
                                                        }
                                                        else
                                                        {
                                                            <span>📸</span>
                                                        }

                                                        @item.PlaceName @(string.IsNullOrWhiteSpace(item.Address) ? "" : $"- {item.Address}")
                                                    </h5>
                                                    <p class="mb-1 text-muted item-desc">@item.Notes</p>
                                                </div>
                                                <div class="text-end">
                                                    <span class="badge bg-light text-dark fs-6 border">
                                                        ⏰ @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                                    </span>
                                                    <br />
                                                    <small class="text-warning fw-bold">★ @((item.Rating ?? 0).ToString("0.0"))</small>
                                                </div>
                                            </div>
                                            <div class="mt-3">
                                                <button class="btn btn-sm btn-outline-secondary"
                                                    data-action="edit-itinerary-item"
                                                    data-item-id="@item.Id"
                                                    data-item-title="@item.PlaceName"
                                                    data-item-desc="@item.Notes">
                                                    Редагувати
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" data-action="delete-itinerary-item" data-item-id="@item.Id">
                                                    Видалити
                                                </button>
                                            </div>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item text-muted text-center py-4">
                                        Для цього дня подій не знайдено.
                                    </li>
                                }
                            </ul>

                            <!-- Додайте кнопку над списком локацій дня -->
                            <button class="btn btn-primary map-optimize-btn" data-day-id="@day.Id">
                                Показати на карті та оптимізувати
                            </button>

                            <!-- Контейнер для карти -->
                            <div id="map-container-@day.Id" style="display:none; height: 400px; width: 100%; margin-top: 15px;"></div>
                            <button class="btn btn-success save-route-btn" style="display:none;" data-day-id="@day.Id">
                                Зберегти новий порядок
                            </button>

                            <!-- Ваш існуючий список локацій. Додайте id, data-item-id та data-address -->
                            <ul class="itinerary-list" id="itinerary-list-@day.Id">
                                @foreach(var item in day.Items.OrderBy(i => i.OrderOffset))
                                {
                                    <!-- Use Address if available. If not, use PlaceName and CityName -->
                                    var searchQuery = !string.IsNullOrWhiteSpace(item.Address) 
                                        ? $"{item.Address}, {Model.CityName}" 
                                        : $"{item.PlaceName}, {Model.CityName}";
                                        
                                    <li class="itinerary-item" data-item-id="@item.Id" data-address="@searchQuery">
                                        @item.PlaceName - @(string.IsNullOrWhiteSpace(item.Address) ? "Адреса не вказана" : item.Address)
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-10">
                <h3 class="text-center mb-4">Адаптація до погоди 🌦️</h3>
                <div class="alert alert-info text-center">
                    Використовуйте цю функцію, щоб адаптувати свій розклад залежно від погоди у місті призначення.
                </div>

                @foreach (var day in Model.Days)
                {
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-header bg-secondary text-white py-3">
                            <h5 class="mb-0">
                                День @day.DayIndex <small class="text-light ms-2">(@day.Date.ToString("dd MMMM, dddd"))</small>
                            </h5>
                        </div>
                        <div class="card-body text-center">
                            <form asp-controller="Trip" asp-action="ActivateRainMode" method="post" class="d-inline-block">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tripDayId" value="@day.Id" />
                                <input type="hidden" name="tripId" value="@Model.TripId" />
                                <button type="submit" class="btn btn-warning btn-sm">
                                    <i class="bi bi-cloud-rain"></i> Адаптувати під дощ (Rain Mode)
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@* Додайте модалку для редагування *@
<div class="modal fade" id="editItemModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редагувати пункт розкладу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editItemId" />
                <div class="mb-3">
                    <label class="form-label">Назва</label>
                    <input type="text" class="form-control" id="editItemTitle" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Опис</label>
                    <textarea class="form-control" id="editItemDesc"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" class="btn btn-primary" data-action="save-itinerary-item">Зберегти</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/views/trip-itinerary.css" asp-append-version="true" />
}

@section Scripts {
    <environment include="Development">
        <script src="~/js/views/trip-itinerary.js" asp-append-version="true"></script>
    </environment>
}

<script src="https://maps.googleapis.com/maps/api/js?key=@Configuration["GoogleMaps:ApiKey"]&callback=initMap" async defer></script>

<script>
    let optimizedOrderIds = [];

    document.querySelectorAll('.map-optimize-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const dayId = this.getAttribute('data-day-id');
            const mapContainer = document.getElementById(`map-container-${dayId}`);
            const saveBtn = document.querySelector(`.save-route-btn[data-day-id="${dayId}"]`);
            
            mapContainer.style.display = 'block';
            saveBtn.style.display = 'inline-block';
            
            const items = document.querySelectorAll(`#itinerary-list-${dayId} .itinerary-item`);
            const addresses = Array.from(items).map(item => ({
                id: item.getAttribute('data-item-id'),
                address: item.getAttribute('data-address')
            }));

            // Add this line to verify what is being sent to Google Maps
            console.log("Calculating route for points:", addresses);

            if (addresses.length < 2) {
                alert("Потрібно хоча б 2 локації для побудови маршруту.");
                return;
            }

            const map = new google.maps.Map(mapContainer, { zoom: 12, center: {lat: 0, lng: 0} });
            const directionsService = new google.maps.DirectionsService();
            const directionsRenderer = new google.maps.DirectionsRenderer({ map: map });

            const origin = addresses[0].address;
            const destination = addresses[addresses.length - 1].address;
            const waypoints = addresses.slice(1, -1).map(addr => ({
                location: addr.address,
                stopover: true
            }));

            directionsService.route({
                origin: origin,
                destination: destination,
                waypoints: waypoints,
                optimizeWaypoints: true, // ВАЖЛИВО: Оптимізація увімкнена
                travelMode: 'WALKING'    // Або 'DRIVING'
            }, (response, status) => {
                if (status === 'OK') {
                    directionsRenderer.setDirections(response);
                    
                    // Отримуємо новий оптимізований порядок індексів
                    const waypointOrder = response.routes[0].waypoint_order;
                    
                    optimizedOrderIds = [addresses[0].id]; // Старт залишається
                    waypointOrder.forEach(index => {
                        optimizedOrderIds.push(addresses[index + 1].id); // +1 бо waypoints не включають старт
                    });
                    optimizedOrderIds.push(addresses[addresses.length - 1].id); // Фініш залишається
                    
                } else {
                    window.alert('Не вдалося побудувати маршрут: ' + status);
                }
            });
        });
    });

    // Збереження
    document.querySelectorAll('.save-route-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const dayId = this.getAttribute('data-day-id');
            
            fetch(`/Trip/OptimizeDayRoute?dayId=${dayId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    // Якщо використовуєте AntiForgery Token:
                    // 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(optimizedOrderIds)
            })
            .then(response => {
                if(response.ok) {
                    location.reload(); // Перезавантажуємо сторінку, щоб показати новий список
                } else {
                    alert("Помилка збереження.");
                }
            });
        });
    });
</script>