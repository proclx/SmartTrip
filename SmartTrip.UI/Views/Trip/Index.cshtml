@model IEnumerable<SmartTrip.UI.ViewModels.TripViewModel>

@{
    ViewData["Title"] = "Мої подорожі";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Мої подорожі</h2>
        <div class="btn-group" role="group">
            <a class="btn btn-outline-primary" asp-action="Favorites">Улюблені подорожі</a>
            <a class="btn btn-primary" asp-action="Create">Додати нову подорож</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Тут будуть ваші подорожі. Додайте першу подорож.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var trip in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@trip.City</h5>
                            <p class="card-text mb-1"><strong>Період:</strong> @trip.StartDate.ToString("dd.MM.yyyy") - @trip.EndDate.ToString("dd.MM.yyyy")</p>
                            <p class="card-text mb-1"><strong>Людей:</strong> @trip.PeopleCount</p>
                            <p class="card-text mb-1"><strong>Рейтинг:</strong> @((trip.Rating.HasValue) ? trip.Rating.Value.ToString() : "не обрано")</p>
                            <p class="card-text mb-1"><strong>Фото:</strong> @(trip.PhotoCount > 0 ? trip.PhotoCount.ToString() : "не додано")</p>
                            <form asp-action="ToggleFavorite" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@trip.Id" />
                                <button type="submit" class="btn btn-sm @(trip.IsFavorite ? "btn-danger" : "btn-outline-danger")" title="Улюблена подорож">
                                    <i class="fas fa-heart"></i> @(trip.IsFavorite ? "В обраному" : "Улюблена")
                                </button>
                            </form>

                            @if (trip.Photos != null && trip.Photos.Any())
                            {
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    @foreach (var photo in trip.Photos.Take(6))
                                    {
                                        <img src="@photo.FilePath" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover;" />
                                    }
                                </div>
                            }

                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@trip.Id">Переглянути</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Itinerary" asp-route-id="@trip.Id">Розклад</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@trip.Id">Редагувати</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>