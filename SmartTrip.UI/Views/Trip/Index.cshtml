@model IEnumerable<SmartTrip.UI.ViewModels.TripViewModel>

@{
    ViewData["Title"] = "Мої подорожі";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Мої подорожі</h2>
        <div class="btn-group" role="group">
            <a class="btn btn-outline-secondary" asp-action="Archived">Архів</a>
            <a class="btn btn-outline-primary" asp-action="Favorites">Улюблені подорожі</a>
            <a class="btn btn-primary" asp-action="Create">Додати нову подорож</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Тут будуть ваші активні подорожі. Додайте першу подорож.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var trip in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@trip.City</h5>
                            <p class="card-text mb-1"><strong>Період:</strong> @trip.StartDate.ToString("dd.MM.yyyy") - @trip.EndDate.ToString("dd.MM.yyyy")</p>
                            <p class="card-text mb-1"><strong>Людей:</strong> @trip.PeopleCount</p>
                            <p class="card-text mb-1"><strong>Рейтинг:</strong> @((trip.Rating.HasValue) ? trip.Rating.Value.ToString() : "не обрано")</p>
                            <p class="card-text mb-1"><strong>Фото:</strong> @(trip.PhotoCount > 0 ? trip.PhotoCount.ToString() : "не додано")</p>

                            <div class="mb-3 mt-2">
                                <form asp-action="ToggleFavorite" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@trip.Id" />
                                    <button type="submit" class="btn btn-sm @(trip.IsFavorite ? "btn-danger" : "btn-outline-danger")" title="Улюблена подорож">
                                        <i class="fas fa-heart"></i> @(trip.IsFavorite ? "В обраному" : "Улюблена")
                                    </button>
                                </form>

                                <form asp-action="ToggleArchive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@trip.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Відправити в архів">
                                        В архів
                                    </button>
                                </form>

                                <form asp-action="Clone" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@trip.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-info" title="Зробити копію">
                                        <i class="bi bi-copy"></i>
                                    </button>
                                </form>
                            </div>

                            @if (trip.Photos != null && trip.Photos.Any())
                            {
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    @foreach (var photo in trip.Photos.Take(6))
                                    {
                                        <img src="@photo.FilePath" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover;" />
                                    }
                                </div>
                            }

                            <div class="d-flex flex-wrap gap-1 mt-auto">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@trip.Id">Переглянути</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Itinerary" asp-route-id="@trip.Id">Розклад</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@trip.Id">Редагувати</a>
                                <button type="button" class="btn btn-sm btn-outline-success" onclick="openPackingModal(@trip.Id)">🎒 Чеклист</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="packingListModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content" id="packingListModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPackingModal(tripId) {
            $('#packingListModalContent').html('<div class="p-5 text-center"><div class="spinner-border text-primary"></div></div>');
            var myModal = new bootstrap.Modal(document.getElementById('packingListModal'));
            myModal.show();
            $.get('/Trip/GetPackingListModal?tripId=' + tripId, function (data) {
                $('#packingListModalContent').html(data);
            });
        }

        function toggleItem(itemId, checkbox) {
            var labelSpan = $(checkbox).siblings('span');
            $.post('/Trip/TogglePackingItem', { itemId: itemId }, function () {
                if(checkbox.checked) {
                    labelSpan.addClass('text-decoration-line-through text-muted');
                } else {
                    labelSpan.removeClass('text-decoration-line-through text-muted');
                }
            });
        }

        function addTripItem(e, tripId) {
            e.preventDefault();
            var name = $('#newItemName').val();
            var cat = $('#newItemCategory').val();
            $.post('/Trip/AddTripPackingItem', { tripId: tripId, name: name, category: cat }, function (data) {
                $('#packingListModalContent').html(data);
            });
        }

        function syncList(tripId) {
            $.post('/Trip/SyncPackingList', { tripId: tripId }, function (data) {
                $('#packingListModalContent').html(data);
            });
        }

        function resetList(tripId) {
            $.post('/Trip/ResetPackingList', { tripId: tripId }, function (data) {
                $('#packingListModalContent').html(data);
            });
        }

        function deleteTripItem(itemId, tripId) {
            if(confirm('Ви впевнені, що хочете видалити цю річ?')) {
                $.post('/Trip/DeleteTripPackingItem', { itemId: itemId, tripId: tripId }, function (data) {
                    $('#packingListModalContent').html(data);
                });
            }
        }
    </script>
}