@{
    ViewData["Title"] = "Забагато запитів";
}

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="display-4 text-danger"><i class="bi bi-shield-exclamation"></i> 429</h1>
            <h2 class="mb-4">Перевищено ліміт запитів</h2>
            <p class="lead">
                Ви зробили занадто багато запитів за короткий проміжок часу. 
                З метою безпеки та стабільності роботи системи ми тимчасово обмежили ваш доступ.
            </p>
            <p class="text-muted mb-4">
                Будь ласка, зачекайте одну хвилину та спробуйте знову.
            </p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3">
                <i class="bi bi-house-door"></i> Повернутися на головну
            </a>
        </div>
    </div>
</div>