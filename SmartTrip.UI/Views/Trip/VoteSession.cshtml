@model SmartTrip.Models.VotingSession
@{
    ViewData["Title"] = "Голосування за локації";
    Layout = "_Layout"; // Використовуйте порожній layout, якщо хочете мобільний вигляд
}

<div class="container text-center mt-5">
    <h2>Обери, куди підемо в @Model.Trip.City.Name!</h2>
    <p>Дочекайся, поки проголосують всі @Model.PeopleCount учасників, щоб ШІ склав ідеальний маршрут.</p>

    <div id="cardDeck" class="mt-4 mx-auto" style="max-width: 400px; position: relative; height: 350px;">
        @foreach (var item in Model.VotingItems)
        {
            <div class="card voting-card shadow-sm" data-id="@item.Id" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: none;">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="card-title">@item.Name</h3>
                    <span class="badge bg-info mb-2">@item.Category</span>
                    <p class="card-text">@item.Description</p>
                </div>
            </div>
        }
    </div>

    <!-- Кнопки голосування -->
    <div class="mt-4" id="controls">
         <button class="btn btn-danger btn-lg rounded-circle mx-3 px-4 py-3 shadow" onclick="vote(false)">
             👎 <br><small>Нудно</small>
         </button>
         <button class="btn btn-success btn-lg rounded-circle mx-3 px-4 py-3 shadow" onclick="vote(true)">
             👍 <br><small>Хочу туди</small>
         </button>
    </div>

    <div id="endMessage" style="display: none;" class="mt-5 text-success">
        <h4>🎉 Ти проголосував(ла) за всі локації!</h4>
        <p>Чекаємо на інших. Як тільки всі завершать, ми повідомимо організатора.</p>
    </div>
</div>

@section Scripts {
<script>
    // Генеруємо тимчасовий ID виборця у localStorage
    let voterId = localStorage.getItem('voterId_@Model.ShareToken');
    if (!voterId) {
        voterId = 'voter_' + Math.random().toString(36).substr(2, 9);
        localStorage.setItem('voterId_@Model.ShareToken', voterId);
    }

    const cards = document.querySelectorAll('.voting-card');
    let currentIndex = 0;

    // Показуємо першу картку
    if (cards.length > 0) {
        cards[currentIndex].style.display = 'block';
    } else {
        document.getElementById('controls').style.display = 'none';
        document.getElementById('endMessage').style.display = 'block';
    }

    async function vote(isLiked) {
        if (currentIndex >= cards.length) return;

        const currentCard = cards[currentIndex];
        const votingItemId = currentCard.getAttribute('data-id');

        // Анімація приховування
        currentCard.classList.add('animate__animated', isLiked ? 'animate__fadeOutRight' : 'animate__fadeOutLeft');
        setTimeout(() => currentCard.style.display = 'none', 500);

        // Відправка на сервер
        fetch('/Trip/SubmitSwipe', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                Token: '@Model.ShareToken',
                VotingItemId: parseInt(votingItemId),
                VoterId: voterId,
                IsLiked: isLiked
            })
        });

        // Перехід до наступної картки
        currentIndex++;
        if (currentIndex < cards.length) {
            setTimeout(() => {
                cards[currentIndex].style.display = 'block';
                cards[currentIndex].classList.add('animate__animated', 'animate__fadeIn');
            }, 300);
        } else {
            setTimeout(() => {
                document.getElementById('controls').style.display = 'none';
                document.getElementById('endMessage').style.display = 'block';
            }, 300);
        }
    }
</script>
<!-- Якщо хочете красиву анімацію, розкоментуйте підключення Animate.css у вашому Layout або тут -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
}