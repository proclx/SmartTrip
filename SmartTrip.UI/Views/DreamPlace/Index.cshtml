@model IEnumerable<SmartTrip.Models.DreamPlace>

@{
    ViewData["Title"] = "Омріяні місця";
}

<div class="container mt-4">
    <h2>Омріяні місця</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Додати нове місце</a>
    </p>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model) {
        <div class="col">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(item.PhotoUrl))
                {
                    <img src="@item.PhotoUrl" class="card-img-top dreamplace-img" alt="@item.Name">
                }
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text text-truncate">@item.Description</p>
                    <p class="card-text"><small class="text-muted">@item.LocationInfo</small></p>
                </div>
                <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                    <form asp-action="PlanTrip" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-sm">Запланувати</button>
                    </form>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Видалити</a>
                </div>
            </div>
        </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/views/dreamplace.css" asp-append-version="true" />
}
