@model IEnumerable<SmartTrip.Models.DreamPlace>

@{
    ViewData["Title"] = "нЛПЁЪМЁ ЛЁЯЖЪ";
}

<div class="container mt-4">
    <h2>нЛПЁЪМЁ ЛЁЯЖЪ</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">дНДЮРХ МНБЕ ЛЁЯЖЕ</a>
    </p>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model) {
        <div class="col">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(item.PhotoUrl))
                {
                    <img src="@item.PhotoUrl" class="card-img-top" alt="@item.Name" style="height:200px; object-fit:cover;">
                }
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text text-truncate">@item.Description</p>
                    <p class="card-text"><small class="text-muted">@item.LocationInfo</small></p>
                </div>
                <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">дЕРЮКЁ</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">пЕДЮЦСБЮРХ</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">бХДЮКХРХ</a>
                </div>
            </div>
        </div>
        }
    </div>
</div>
