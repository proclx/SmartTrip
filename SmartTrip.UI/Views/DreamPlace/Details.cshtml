@model SmartTrip.Models.DreamPlace

@{
    ViewData["Title"] = "Деталі місця";
}

<div class="container mt-4">
    <h2>Деталі про омріяне місце</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl" alt="@Model.Name" class="img-fluid rounded shadow mb-3" />
            }
            else
            {
                <p class="text-muted">Фотографія відсутня</p>
            }
        </div>
        <div class="col-md-6">
            <h3>@Model.Name</h3>
            <p><strong>Опис:</strong></p>
            <p>@Model.Description</p>
            
            <p><strong>Локація:</strong></p>
            <p>@(string.IsNullOrEmpty(Model.LocationInfo) ? "Не вказано" : Model.LocationInfo)</p>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
                <a asp-action="Index" class="btn btn-secondary">Повернутися до списку</a>
            </div>
        </div>
    </div>
</div>