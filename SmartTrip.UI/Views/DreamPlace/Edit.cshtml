@model SmartTrip.Models.DreamPlace

@{
    ViewData["Title"] = "Редагувати омріяне місце";
}

<div class="container mt-4">
    <h2>Редагувати омріяне місце</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PhotoUrl" />
                
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label">Назва місця</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label">Опис</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="LocationInfo" class="control-label">Локація / Деталі розташування</label>
                    <input asp-for="LocationInfo" class="form-control" />
                    <span asp-validation-for="LocationInfo" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label class="control-label">Оновити фотографію (Опціонально)</label>
                    <input type="file" name="photoFile" class="form-control" accept="image/*" />
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <div class="mt-2">
                            <img src="@Model.PhotoUrl" alt="@Model.Name" style="max-width:200px;" />
                            <small class="form-text text-muted d-block">Поточне фото</small>
                        </div>
                    }
                </div>
                
                <div class="form-group mt-3">
                    <input type="submit" value="Зберегти зміни" class="btn btn-warning" />
                    <a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}