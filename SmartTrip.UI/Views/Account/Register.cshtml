@model SmartTrip.UI.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">Створити акаунт</h2>

                    <form method="post" asp-action="Register" asp-controller="Account">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label">Ім'я</label>
                                <input asp-for="FirstName" class="form-control" placeholder="Тарас" />
                                <span asp-validation-for="FirstName" class="text-danger form-text"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label">Прізвище</label>
                                <input asp-for="LastName" class="form-control" placeholder="Шевченко" />
                                <span asp-validation-for="LastName" class="text-danger form-text"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Електронна пошта</label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger form-text"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Пароль</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger form-text"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Підтвердіть пароль</label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger form-text"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Зареєструватися</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}