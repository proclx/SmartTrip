@model SmartTrip.UI.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "бУЁД";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-lg">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">бУЁД С ЯХЯРЕЛС</h2>

                    <form method="post" asp-action="Login" asp-controller="Account">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">еКЕЙРПНММЮ ОНЬРЮ</label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger form-text"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">оЮПНКЭ</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger form-text"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">гЮОЮЛ'ЪРЮРХ ЛЕМЕ</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">сБЁИРХ</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
